# .editorconfig — shared by ktlint and IDEs
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120

# ktlint-specific rules
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled
# Allow multiline strings to not follow indent rules (embedded HTML/CSS)
ktlint_standard_multiline-expression-wrapping = disabled

# Test files: SSH key strings and long assertion messages legitimately exceed 120 chars.
# Disable max-line-length for test sources only.
[app/src/test/**/*.kt]
max_line_length = off
